# Mapbox Configuration
# Get your free token from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Mapbox map styles
NEXT_PUBLIC_MAPBOX_MAP_STYLE_DARK=mapbox://styles/mapbox/dark-v11
NEXT_PUBLIC_MAPBOX_MAP_STYLE_LIGHT=mapbox://styles/mapbox/light-v11

# Strava OAuth
# Create an app at https://www.strava.com/settings/api
# Required scopes: read, activity:read_all
NEXT_PUBLIC_STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
